# CDS 환경변수 샘플 — 복사 후 .env 로 저장하고 값을 채우세요 (.env 는 Git에 올리지 않음)

# JWT (웹 server.js 와 동일한 값 사용)
CDS_JWT_SECRET=change-me-in-production

# AWS IAM Roles Anywhere (~/.aws/config 의 프로필명)
CDS_AWS_PROFILE=my-cds-profile

# S3 등급별 버킷 (미설정 시 s3_reader.py 기본값: n2sf-c / n2sf-s / n2sf-o)
CDS_S3_BUCKET_C=n2sf-c
CDS_S3_BUCKET_S=n2sf-s
CDS_S3_BUCKET_O=n2sf-o

AWS_REGION=ap-northeast-2
